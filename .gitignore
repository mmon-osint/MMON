*.log
vm1/logs/
vm2/logs/
vm3/logs/
backend/logs/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Database dumps
*.sql.bak
*.dump

# Redis
dump.rdb

# Node (se usato per build tool dashboard)
node_modules/

# Ollama models
models/
