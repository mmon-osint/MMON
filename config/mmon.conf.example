; ─────────────────────────────────────────────────────────────
; MMON Configuration — generato dal Setup Wizard
; NON COMMITTARE IN REPO — contiene secret
; ─────────────────────────────────────────────────────────────

[general]
deploy_mode = personal          ; personal | company
instance_name = MMON
version = 1.0.0

[target]
company_name =
domains =                       ; comma-separated: example.com,sub.example.com
public_ips =                    ; comma-separated: 1.2.3.4,5.6.7.8
emails =                        ; comma-separated: admin@example.com,ceo@example.com

[social]
usernames =                     ; comma-separated: johndoe,janedoe
full_names =                    ; comma-separated: John Doe,Jane Doe

[technologies]
; lista delle tecnologie usate dall'azienda (per CVE feed)
web_server =                    ; apache,nginx,iis,...
database =                      ; postgresql,mysql,mongodb,...
language =                      ; python,java,php,...
cms =                           ; wordpress,drupal,...
cloud =                         ; aws,azure,gcp,...
security =                      ; cloudflare,crowdstrike,...
mail =                          ; exchange,postfix,...
network =                       ; cisco,fortinet,...

[sector]
industry =                      ; finance,healthcare,technology,...
products =                      ; comma-separated: product descriptions
competitors =                   ; comma-separated: competitor names

[api_keys]
shodan =
criminal_ip =
quake360 =

[infrastructure]
backend_ip = 10.0.0.10
vm1_ip = 10.0.0.11
vm2_ip = 10.0.0.12
vm3_ip = 10.0.0.13

[database]
host = 127.0.0.1
port = 5432
name = mmon_db
user = mmon
password =                      ; generata da setup_backend.sh

[redis]
host = 127.0.0.1
port = 6379
db = 0

[tor]
socks_port = 9050
control_port = 9051
control_password =

[telegram]
api_id =
api_hash =
phone =

[scheduler]
scan_interval_hours = 24
max_concurrent_tools = 3

[jwt]
secret_key =                    ; generata random al primo avvio
algorithm = HS256
expire_minutes = 1440           ; 24h

[keycloak]
; Solo per deploy_mode = company
enabled = false
server_url =                    ; https://keycloak.example.com
realm = mmon
client_id = mmon-dashboard
client_secret =

[ollama]
base_url = http://127.0.0.1:11434
model = qwen2.5:14b
timeout = 120
